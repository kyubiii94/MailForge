# Clé API Gemini (Google AI) - requise pour l'analyse IA (ADN de marque, amélioration de texte, design email)
# Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Base de données Neon PostgreSQL - requise pour la persistance des campagnes
# Obtenir une URL : https://console.neon.tech
DATABASE_URL=

# Vercel Blob (uniquement en prod sur Vercel) - créé automatiquement quand vous ajoutez un Blob Store dans Storage
# BLOB_READ_WRITE_TOKEN=
