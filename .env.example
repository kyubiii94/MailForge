# MailForge AI - Environment Variables

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API
GEMINI_API_KEY=xxxxx

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mailforge

# S3 / Cloudflare R2 Storage
STORAGE_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=xxxxx
STORAGE_SECRET_KEY=xxxxx
STORAGE_BUCKET=mailforge-media

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxxxx
CLERK_SECRET_KEY=sk_xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
