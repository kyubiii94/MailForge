# MailForge AI - Environment Variables
# Variables marked [REQUIRED] must be set for the app to work on Vercel

# Anthropic Claude API [REQUIRED]
ANTHROPIC_API_KEY=sk-ant-xxxxx

# App [REQUIRED for Vercel]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Below: needed for production, not for MVP ---

# Google Gemini API (optional)
GEMINI_API_KEY=xxxxx

# Database - PostgreSQL (MVP uses in-memory DB)
DATABASE_URL=postgresql://user:password@localhost:5432/mailforge

# S3 / Cloudflare R2 Storage (MVP uses base64 data URLs)
STORAGE_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=xxxxx
STORAGE_SECRET_KEY=xxxxx
STORAGE_BUCKET=mailforge-media

# Auth - Clerk (not yet integrated)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxxxx
CLERK_SECRET_KEY=sk_xxxxx
